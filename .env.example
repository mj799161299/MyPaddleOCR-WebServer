# ============================================================
#  OCR扫描工具 Web版 — 环境变量配置
#  复制此文件为 backend/.env 并修改
# ============================================================

# ---- 运行模式 ----
# 开发模式（开启后返回详细错误堆栈，生产环境务必关闭）
DEBUG=false

# 监听地址与端口
HOST=0.0.0.0
PORT=8000

# ---- HTTPS / SSL（可选） ----
# 启用 HTTPS 后服务监听 https://，需要同时提供证书和私钥
#SSL_ENABLED=true
#SSL_CERTFILE=./cert.pem
#SSL_KEYFILE=./key.pem
#SSL_KEYFILE_PASSWORD=

# ---- JWT 认证 ----
# 生产环境务必修改为随机长字符串（留空或默认值会在启动时自动生成 64 位随机密钥）
SECRET_KEY=
#AUTO_GENERATE_SECRET_KEY=false   # 设为 false 可禁用自动密钥生成
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- 数据库 ----
DATABASE_URL=sqlite:///./ocr_web.db

# ---- 文件存储 ----
#UPLOAD_DIR=uploads
#EXPORT_DIR=exports
MAX_FILE_SIZE=10485760
MAX_REQUEST_SIZE=52428800

# ---- OCR 服务 ----
OCR_SERVER_URL=http://127.0.0.1:7950/v1

# ---- CORS 跨域 ----
# 前端开发地址，多个地址用逗号分隔
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
CORS_ALLOW_CREDENTIALS=true

# ---- 受信主机 ----
# 逗号分隔的合法 Host 头域名（生产环境建议设置具体值，防止 Host 头注入攻击）
# 设为 ["*"] 不校验（仅开发环境）
TRUSTED_HOSTS='["*"]'

# ---- 速率限制 ----
# 总开关（false 则关闭所有限速）
RATE_LIMIT_ENABLED=true

# 默认限速：窗口内最大请求数 / 时间单位 (second / minute / hour / day)
RATE_LIMIT_DEFAULT=120/minute

# 登录接口限速（防暴力破解）
RATE_LIMIT_LOGIN=10/minute

# 注册接口限速（防批量注册）
RATE_LIMIT_REGISTER=5/minute

# 文件上传接口限速
RATE_LIMIT_UPLOAD=30/minute

# ---- 前端端口（仅提示，后端不读取） ----
FRONTEND_PORT=5173
